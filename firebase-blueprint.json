{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role in the application."
        },
        "phone": {
          "type": "string",
          "description": "User's phone number."
        },
        "bloodGroup": {
          "type": "string",
          "description": "User's blood group."
        },
        "permanentDistrict": {
          "type": "string",
          "description": "User's permanent district."
        },
        "permanentAddress": {
          "type": "string",
          "description": "User's permanent address."
        },
        "currentDistrict": {
          "type": "string",
          "description": "User's current district."
        },
        "currentAddress": {
          "type": "string",
          "description": "User's current address."
        },
        "lastDonationDate": {
          "type": "string",
          "description": "User's last donation date."
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female"],
          "description": "User's gender."
        }
      },
      "required": ["name", "email", "role", "phone", "bloodGroup", "gender", "permanentDistrict", "permanentAddress", "currentDistrict", "currentAddress"]
    },
    "Donor": {
      "title": "Donor",
      "description": "Information about a blood donor.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Donor's name."
        },
        "phone": {
          "type": "string",
          "description": "Donor's phone number."
        },
        "bloodGroup": {
          "type": "string",
          "description": "Donor's blood group."
        },
        "address": {
          "type": "string",
          "description": "Donor's address."
        },
        "lastDonationDate": {
          "type": "string",
          "description": "Donor's last donation date (YYYY-MM-DD)."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who added this donor record."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the donor record was created."
        }
      },
      "required": ["name", "phone", "bloodGroup", "address", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "Feedback or questions submitted by users.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person submitting the question."
        },
        "text": {
          "type": "string",
          "description": "The content of the question or feedback."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the question was submitted."
        }
      },
      "required": ["name", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "donors/{donorId}": {
      "schema": "Donor",
      "description": "Collection of blood donor records."
    },
    "questions/{questionId}": {
      "schema": "Question",
      "description": "Collection of submitted questions and feedback."
    }
  }
}
